    SliderKnob.BorderColor3 = Color3.fromRGB(100, 100, 100)
    SliderKnob.Parent = SliderContainer

    local dragging = false
    local function SetSmoothingValue(value)
        value = math.clamp(value, 0.01, 1)
        Aimbot.Smoothing = value
        SmoothingLabel.Text = "Smoothing: " .. string.format("%.2f", value)
        local ratio = (value - 0.01) / (1 - 0.01)
        local containerWidth = SliderContainer.AbsoluteSize.X
        if containerWidth > 0 then
            local knobWidth = SliderKnob.AbsoluteSize.X
            local xOffset = ratio * containerWidth - knobWidth / 2
            SliderKnob.Position = UDim2.new(0, xOffset, 0.5, -10)
            SliderFill.Size = UDim2.new(ratio, 0, 1, 0)
        end
    end
    local function UpdateSmoothingFromKnob()
        local containerWidth = SliderContainer.AbsoluteSize.X
        if containerWidth <= 0 then return end
        local mousePos = UserInputService:GetMouseLocation()
        local containerLeft = SliderContainer.AbsolutePosition.X
        local relativeX = mousePos.X - containerLeft
        local ratio = math.clamp(relativeX / containerWidth, 0, 1)
        local value = 0.01 + (1 - 0.01) * ratio
        SetSmoothingValue(value)
    end
    SliderKnob.MouseButton1Down:Connect(function()
        dragging = true
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then UpdateSmoothingFromKnob() end
    end)
    task.spawn(function()
        task.wait(0.3)
        SetSmoothingValue(Aimbot.Smoothing)
    end)

